#!/usr/bin/env bash
# Repository-managed git pre-commit hook.
#
# Installed by `python3 scripts/install_git_hook.py` (which copies this file
# into `.git/hooks/pre-commit`). It delegates to `scripts/pre_commit_check.sh`
# so the same gate runs locally and in CI.
#
# Skips work for commits that touch no Python file under `scripts/` to keep
# pure-markdown commits fast.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Detect Python changes in the working tree OR the index. We lint everything
# touched by this commit (staged + unstaged) so contributors can't sneak a
# style fix past `git commit --amend`.
PY_TOUCHED=$( (git diff --cached --name-only --diff-filter=AM ; git diff --name-only --diff-filter=AM) \
  | sort -u \
  | grep -E '^scripts/.*\.py$' || true)

if [ -z "${PY_TOUCHED}" ]; then
  exit 0
fi

exec bash "${REPO_ROOT}/scripts/pre_commit_check.sh" --staged-only