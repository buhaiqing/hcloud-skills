# .env.example - Environment configuration for hcloud-skills sandbox
# Copy to .env and fill in your credentials

# Required: Huawei Cloud Access Key ID
HW_ACCESS_KEY_ID=your-access-key-id

# Required: Huawei Cloud Secret Access Key
HW_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: Default region (defaults to cn-north-4 if not set)
HW_REGION_ID=cn-north-4

# Optional: Project ID (required for some services)
HW_PROJECT_ID=your-project-id

# Optional: Timezone
TZ=Asia/Shanghai